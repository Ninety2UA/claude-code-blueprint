flowchart TB
    subgraph DESIGN_PHASE ["Design Phase"]
        direction LR
        BRAIN["Brainstorming<br/><i>Explore options</i>"]
        WPLAN["Writing Plans<br/><i>Bite-sized tasks</i>"]
    end

    subgraph EXECUTION_PHASE ["Execution Phase"]
        direction LR
        EXEC["Executing Plans<br/><i>Batch execution</i>"]
        TDD["Test-Driven Dev<br/><i>Red-Green-Refactor</i>"]
        SUBAGENT["Subagent-Driven<br/><i>Fresh context per task</i>"]
        PARALLEL["Parallel Agents<br/><i>Independent domains</i>"]
        WORKTREE["Git Worktrees<br/><i>Isolated workspace</i>"]
    end

    subgraph QUALITY_PHASE ["Quality Phase"]
        direction LR
        DEBUG["Systematic Debugging<br/><i>Root cause first</i>"]
        VERIFY["Verification<br/><i>Evidence-based</i>"]
        REQREV["Requesting Review<br/><i>Dispatch reviewer</i>"]
        RECREV["Receiving Review<br/><i>Evaluate feedback</i>"]
    end

    subgraph COMPLETION_PHASE ["Completion Phase"]
        direction LR
        FINISH_SKILL["Finishing Branch<br/><i>Merge workflow</i>"]
        WRAP["Session Wrap<br/><i>Document & update</i>"]
    end

    subgraph META_PHASE ["Meta"]
        direction LR
        WSKILL["Writing Skills<br/><i>Create new skills</i>"]
    end

    BRAIN --> WPLAN
    WPLAN --> EXEC
    WPLAN --> SUBAGENT
    EXEC --> TDD
    SUBAGENT --> TDD
    WORKTREE -.-> EXEC
    WORKTREE -.-> SUBAGENT
    PARALLEL -.-> TDD
    TDD --> VERIFY
    DEBUG -.-> TDD
    VERIFY --> REQREV
    REQREV --> RECREV
    RECREV --> FINISH_SKILL
    FINISH_SKILL --> WRAP

